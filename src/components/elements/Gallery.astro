---
import { Splide, SplideSlide } from 'astro-splide'
import { Image } from 'astro:assets'

// Eagerly import every gallery image so astro:assets optimizes them
// (responsive srcset + webp) instead of shipping the multi-MB originals.
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/gallery/*.{jpg,jpeg,png}',
  { eager: true }
)

const attribution = {
    name: "Bill Grinnell",
    link: "https://www.facebook.com/profile.php?id=100089332627436"
}

const slides = Object.entries(images)
  .sort(() => Math.random() - 0.5)
  .map(([path, mod]) => ({
    img: mod.default,
    alt: path.split('/').pop()?.replace(/\.[^.]+$/, '') ?? '',
  }))
---
<Splide
  class='not-content'
  options={ {
    type: 'loop',
    interval: 3000,
    autoplay: true,
    pauseOnHover: true,
  } }
>
  {slides.map((slide) => (
    <SplideSlide>
      <figure>
        <Image src={slide.img} alt={slide.alt} />
        <figcaption>
          <strong>Photo by</strong>{' '}
          <a href={attribution.link} target='_blank' rel='noopener noreferrer'>
            {attribution.name}
          </a>
        </figcaption>
      </figure>
    </SplideSlide>
  ))}
</Splide>

<style>
  figure {
    position: relative;
    margin: 0;
    line-height: 0; /* remove inline gap under the image */
    background: #000; /* fills the letterbox/pillarbox bars */
  }
  figure :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    /* every slide shares this box so the carousel doesn't jump between
       landscape and portrait images */
    aspect-ratio: 16 / 9;
    object-fit: contain; /* show the whole image; never crop */
    object-position: center;
  }
  figcaption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.75rem 1rem;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    font-size: 0.875rem;
    line-height: 1.3;
  }
  figcaption a {
    color: inherit;
    text-decoration: underline;
  }
</style>
